# Database (optional - app works without DB for now)
DATABASE_URL=postgresql://user:password@host:5432/pacfi_ai

# ============================================================================
# PACIFICA NETWORK CONFIGURATION
# ============================================================================
# For Testnet (Hackathon development):
#   - API: https://test-api.pacifica.fi/api/v1
#   - App: https://test-app.pacifica.fi/
#   - Solana Network: Devnet
# For Mainnet:
#   - API: https://api.pacifica.fi/api/v1  
#   - App: https://app.pacifica.fi/
#   - Solana Network: Mainnet-Beta

# Pacifica API Agent Keys (Testnet)
# Get from: https://app.pacifica.fi/apikey
PACIFICA_AGENT_PRIVATE_KEY=your_agent_private_key
PACIFICA_AGENT_ACCOUNT=your_agent_account_address

# Pacifica API Endpoint
PACIFICA_BASE_URL=https://test-api.pacifica.fi/api/v1

# Solana RPC Endpoint (for wallet connections)
# Testnet: https://api.devnet.solana.com
# Mainnet: https://api.mainnet-beta.solana.com
PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# ============================================================================
# AI Model APIs (choose one - priority: OpenRouter > GLM > DashScope)
# ============================================================================
# OpenRouter: https://openrouter.ai/keys (supports Qwen, GLM, Claude, etc.)
OPENROUTER_API_KEY=
# GLM (Zhipu AI): https://open.bigmodel.cn/
GLM_API_KEY=
# DashScope (Qwen): https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# Frontend
PUBLIC_API_URL=http://localhost:3001

# Backend
NODE_ENV=production
PORT=3001
API_URL=http://localhost:3001

# JWT (generate a secure random string)
JWT_SECRET=your_secure_jwt_secret_here