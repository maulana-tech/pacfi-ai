# Database
DATABASE_URL=postgresql://user:password@host:5432/pacfi_ai

# Pacifica agent wallet (optional, for backend-managed execution)
# Base58 secret key for the agent wallet authorized on Pacifica
PACIFICA_AGENT_PRIVATE_KEY=your_base58_agent_secret_key
PACIFICA_AGENT_PUBLIC_KEY=your_agent_wallet_public_key
# The Pacifica account that this backend is allowed to trade for in agent mode
PACIFICA_AGENT_ACCOUNT=your_authorized_main_wallet

# Qwen AI Model Studio
DASHSCOPE_API_KEY=your_dashscope_key_here

# Frontend
PUBLIC_API_URL=http://localhost:3001

# Backend
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
