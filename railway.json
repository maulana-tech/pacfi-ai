{
  "$schema": "https://railway.app/schema.json",
  "name": "pacfi-ai",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "corepack enable && pnpm install && pnpm run build",
    "startCommand": "cd apps/backend && node dist/index.js",
    "env": {
      "NODE_VERSION": "20"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
