---
import DashboardLayout from '../components/DashboardLayout';
import StatCard from '../components/StatCard';
import Card from '../components/Card';
import Table from '../components/Table';

// Mock data untuk demo
const portfolioStats = [
  { label: 'Total Balance', value: '$24,582.50', change: 12.5 },
  { label: 'Portfolio Value', value: '$18,450.00', change: 8.2 },
  { label: 'AI Win Rate', value: '68.5%', change: 5.3 },
  { label: 'Monthly Return', value: '+$2,150.00', change: 15.8 },
];

const recentTrades = [
  {
    id: '1',
    symbol: 'BTC/USD',
    side: 'BUY',
    amount: '0.5',
    price: '$45,230',
    status: 'Closed',
    pnl: '+$1,250',
  },
  {
    id: '2',
    symbol: 'ETH/USD',
    side: 'SELL',
    amount: '2.5',
    price: '$2,850',
    status: 'Closed',
    pnl: '+$450',
  },
  {
    id: '3',
    symbol: 'SOL/USD',
    side: 'BUY',
    amount: '10',
    price: '$145.50',
    status: 'Open',
    pnl: '+$125',
  },
];

const columns = [
  { key: 'symbol', label: 'Symbol' },
  { key: 'side', label: 'Side' },
  { key: 'amount', label: 'Amount' },
  { key: 'price', label: 'Price' },
  { key: 'status', label: 'Status' },
  { key: 'pnl', label: 'P&L' },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard - Pacfi AI</title>
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background-color: #f9fafb;
        color: #1f2937;
      }

      .grid-cols-4 {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
      }

      @media (max-width: 1024px) {
        .grid-cols-4 {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 640px) {
        .grid-cols-4 {
          grid-template-columns: 1fr;
        }
      }

      .mt-8 {
        margin-top: 2rem;
      }

      .space-y-6 > * + * {
        margin-top: 1.5rem;
      }
    </style>
  </head>
  <body>
    <DashboardLayout client:load>
      <div className="space-y-6">
        {/* Portfolio Overview */}
        <div>
          <h2 className="text-xl font-bold text-gray-900 mb-4">Portfolio Overview</h2>
          <div className="grid-cols-4">
            {portfolioStats.map((stat) => (
              <StatCard
                key={stat.label}
                label={stat.label}
                value={stat.value}
                change={stat.change}
              />
            ))}
          </div>
        </div>

        {/* AI Swarm Status */}
        <Card title="AI Swarm Status" subtitle="Real-time agent activity">
          <div className="space-y-4">
            <div className="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
              <div>
                <p className="font-medium text-gray-900">Market Analyst</p>
                <p className="text-sm text-gray-600">Analyzing technical patterns...</p>
              </div>
              <span className="inline-block w-3 h-3 bg-success rounded-full"></span>
            </div>
            <div className="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
              <div>
                <p className="font-medium text-gray-900">Sentiment Agent</p>
                <p className="text-sm text-gray-600">Monitoring market sentiment...</p>
              </div>
              <span className="inline-block w-3 h-3 bg-success rounded-full"></span>
            </div>
            <div className="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
              <div>
                <p className="font-medium text-gray-900">Risk Manager</p>
                <p className="text-sm text-gray-600">Calculating position sizes...</p>
              </div>
              <span className="inline-block w-3 h-3 bg-success rounded-full"></span>
            </div>
          </div>
        </Card>

        {/* Recent Trades */}
        <Card title="Recent Trades" subtitle="Last 10 trading activities">
          <Table columns={columns} data={recentTrades} />
        </Card>
      </div>
    </DashboardLayout>
  </body>
</html>
