---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pacfi AI — Autonomous Trading on Pacifica">
  <div class="landing">

    <!-- Header -->
    <header class="header" id="header">
      <div class="header-inner">
        <a href="/" class="logo">
          <div class="logo-icon">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M3 13 L9 5 L15 9" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="15" cy="9" r="2" fill="white"/>
            </svg>
          </div>
          <span class="logo-text">Pacfi AI</span>
        </a>
        <nav class="nav" id="nav">
          <a href="#features">Features</a>
          <a href="#how-it-works">How it works</a>
          <a href="/leaderboard">Leaderboard</a>
        </nav>
        <div class="header-right">
          <a href="/dashboard" class="btn-launch">Launch App</a>
          <button class="hamburger" id="hamburger" aria-label="Toggle menu">
            <span></span><span></span><span></span>
          </button>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-bg-glow"></div>
      <div class="hero-bg-grid"></div>

      <!-- Ticker bar top -->
      <div class="hero-ticker">
        <div class="ticker-track">
          <span class="ticker-item"><span class="ticker-sym">BTC-PERP</span><span class="ticker-val up">$67,482.50</span><span class="ticker-chg up">+2.14%</span></span>
          <span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-sym">ETH-PERP</span><span class="ticker-val up">$3,521.80</span><span class="ticker-chg up">+1.87%</span></span>
          <span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-sym">SOL-PERP</span><span class="ticker-val down">$142.30</span><span class="ticker-chg down">-0.62%</span></span>
          <span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-sym">ARB-PERP</span><span class="ticker-val up">$1.284</span><span class="ticker-chg up">+3.41%</span></span>
          <span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-sym">DOGE-PERP</span><span class="ticker-val down">$0.1621</span><span class="ticker-chg down">-1.20%</span></span>
          <span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-sym">AVAX-PERP</span><span class="ticker-val up">$38.45</span><span class="ticker-chg up">+0.99%</span></span>
          <span class="ticker-sep">|</span>
          <!-- duplicate for seamless scroll -->
          <span class="ticker-item"><span class="ticker-sym">BTC-PERP</span><span class="ticker-val up">$67,482.50</span><span class="ticker-chg up">+2.14%</span></span>
          <span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-sym">ETH-PERP</span><span class="ticker-val up">$3,521.80</span><span class="ticker-chg up">+1.87%</span></span>
          <span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-sym">SOL-PERP</span><span class="ticker-val down">$142.30</span><span class="ticker-chg down">-0.62%</span></span>
          <span class="ticker-sep">|</span>
          <span class="ticker-item"><span class="ticker-sym">ARB-PERP</span><span class="ticker-val up">$1.284</span><span class="ticker-chg up">+3.41%</span></span>
        </div>
      </div>

      <div class="hero-inner">
        <!-- Left: Text -->
        <div class="hero-left">
          <div class="hero-badge">
            <span class="dot dot-pulse"></span>
            <span>LIVE</span>
            <span class="badge-divider"></span>
            Pacifica Hackathon &amp; Builder Program
          </div>
          <h1 class="hero-title">
            Autonomous AI<br/>Trading on<br/>
            <span class="hero-title-gradient">Pacifica Perpetuals</span>
          </h1>
          <p class="hero-desc">
            A multi-agent Qwen swarm that continuously analyzes markets,
            manages risk, and executes perpetual trades — fully automated,
            fully transparent.
          </p>
          <div class="hero-actions">
            <a href="/dashboard" class="btn-hero-primary">
              Launch App
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#how-it-works" class="btn-hero-outline">How it works</a>
          </div>
          <div class="hero-stats">
            <div class="hero-stat">
              <span class="hero-stat-value c-green">68.5%</span>
              <span class="hero-stat-label">Win Rate</span>
            </div>
            <div class="hero-stat-div"></div>
            <div class="hero-stat">
              <span class="hero-stat-value c-blue">4</span>
              <span class="hero-stat-label">AI Agents</span>
            </div>
            <div class="hero-stat-div"></div>
            <div class="hero-stat">
              <span class="hero-stat-value c-purple">142</span>
              <span class="hero-stat-label">Trades</span>
            </div>
            <div class="hero-stat-div"></div>
            <div class="hero-stat">
              <span class="hero-stat-value c-amber">$0</span>
              <span class="hero-stat-label">Setup Cost</span>
            </div>
          </div>
        </div>

        <!-- Right: Terminal UI Mockup -->
        <div class="hero-right">
          <div class="terminal">
            <!-- Terminal header -->
            <div class="term-header">
              <div class="term-header-left">
                <span class="term-dot term-dot-red"></span>
                <span class="term-dot term-dot-yellow"></span>
                <span class="term-dot term-dot-green"></span>
              </div>
              <span class="term-title">SWARM TERMINAL // BTC-PERP</span>
              <span class="term-live"><span class="dot dot-pulse" style="width:5px;height:5px;"></span> LIVE</span>
            </div>

            <!-- Price row -->
            <div class="term-price-row">
              <div class="term-price-main">
                <span class="term-price">$67,482.50</span>
                <span class="term-price-chg up">▲ +2.14%</span>
              </div>
              <div class="term-price-meta">
                <span>24h Vol: <strong>$4.2B</strong></span>
                <span>OI: <strong>$812M</strong></span>
                <span>Mark: <strong>$67,479.10</strong></span>
              </div>
            </div>

            <!-- SVG Sparkline chart -->
            <div class="term-chart">
              <div class="term-chart-labels">
                <span>$68.2k</span>
                <span>$67.8k</span>
                <span>$67.4k</span>
                <span>$67.0k</span>
              </div>
              <svg class="term-spark" viewBox="0 0 340 72" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="sparkGrad" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="#3B82F6" stop-opacity="0.25"/>
                    <stop offset="100%" stop-color="#3B82F6" stop-opacity="0"/>
                  </linearGradient>
                </defs>
                <!-- Area fill -->
                <path d="M0,55 L12,50 L28,45 L45,48 L60,40 L75,43 L90,35 L105,38 L118,30 L132,32 L148,20 L162,25 L175,18 L190,22 L205,15 L218,20 L232,12 L248,16 L262,22 L275,18 L290,24 L305,20 L320,26 L340,22 L340,72 L0,72 Z" fill="url(#sparkGrad)"/>
                <!-- Line -->
                <path d="M0,55 L12,50 L28,45 L45,48 L60,40 L75,43 L90,35 L105,38 L118,30 L132,32 L148,20 L162,25 L175,18 L190,22 L205,15 L218,20 L232,12 L248,16 L262,22 L275,18 L290,24 L305,20 L320,26 L340,22" fill="none" stroke="#3B82F6" stroke-width="1.5"/>
                <!-- Current price dot -->
                <circle cx="340" cy="22" r="3" fill="#3B82F6"/>
                <circle cx="340" cy="22" r="6" fill="#3B82F6" fill-opacity="0.2"/>
              </svg>
              <div class="term-chart-times">
                <span>6h</span><span>12h</span><span>18h</span><span>NOW</span>
              </div>
            </div>

            <!-- Agent grid -->
            <div class="term-section-label">// AI AGENT STATUS</div>
            <div class="term-agents">
              <div class="term-agent">
                <div class="term-agent-top">
                  <span class="term-agent-name">Market Analyst</span>
                  <span class="term-agent-decision buy">BUY</span>
                </div>
                <div class="term-conf-bar"><div class="term-conf-fill" style="width:84%;background:#3B82F6"></div></div>
                <span class="term-conf-label">Confidence: <strong>84%</strong></span>
              </div>
              <div class="term-agent">
                <div class="term-agent-top">
                  <span class="term-agent-name">Sentiment Agent</span>
                  <span class="term-agent-decision buy">BUY</span>
                </div>
                <div class="term-conf-bar"><div class="term-conf-fill" style="width:71%;background:#8B5CF6"></div></div>
                <span class="term-conf-label">Confidence: <strong>71%</strong></span>
              </div>
              <div class="term-agent">
                <div class="term-agent-top">
                  <span class="term-agent-name">Risk Manager</span>
                  <span class="term-agent-decision hold">HOLD</span>
                </div>
                <div class="term-conf-bar"><div class="term-conf-fill" style="width:55%;background:#F59E0B"></div></div>
                <span class="term-conf-label">Confidence: <strong>55%</strong></span>
              </div>
              <div class="term-agent">
                <div class="term-agent-top">
                  <span class="term-agent-name">Coordinator</span>
                  <span class="term-agent-decision buy">BUY</span>
                </div>
                <div class="term-conf-bar"><div class="term-conf-fill" style="width:76%;background:#10B981"></div></div>
                <span class="term-conf-label">Confidence: <strong>76%</strong></span>
              </div>
            </div>

            <!-- Recent orders -->
            <div class="term-section-label">// RECENT EXECUTIONS</div>
            <div class="term-orders">
              <div class="term-order-row">
                <span class="term-order-side buy">LONG</span>
                <span class="term-order-sym">BTC-PERP</span>
                <span class="term-order-size">0.04 BTC</span>
                <span class="term-order-pnl up">+$124.30</span>
                <span class="term-order-time">2m ago</span>
              </div>
              <div class="term-order-row">
                <span class="term-order-side sell">SHORT</span>
                <span class="term-order-sym">ETH-PERP</span>
                <span class="term-order-size">0.85 ETH</span>
                <span class="term-order-pnl down">-$18.40</span>
                <span class="term-order-time">7m ago</span>
              </div>
              <div class="term-order-row">
                <span class="term-order-side buy">LONG</span>
                <span class="term-order-sym">SOL-PERP</span>
                <span class="term-order-size">12.0 SOL</span>
                <span class="term-order-pnl up">+$67.10</span>
                <span class="term-order-time">14m ago</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="features" id="features">
      <div class="section-inner">
        <div class="section-eyebrow">Features</div>
        <h2 class="section-title">Everything you need to trade smarter</h2>
        <p class="section-subtitle">A complete autonomous trading stack — from market analysis to on-chain execution.</p>
        <div class="features-grid">

          <div class="feature-card">
            <div class="feature-icon feature-icon-blue">
              <svg width="22" height="22" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/><circle cx="3.5" cy="5" r="2" stroke="currentColor" stroke-width="1.5"/><circle cx="16.5" cy="5" r="2" stroke="currentColor" stroke-width="1.5"/><circle cx="3.5" cy="15" r="2" stroke="currentColor" stroke-width="1.5"/><circle cx="16.5" cy="15" r="2" stroke="currentColor" stroke-width="1.5"/><line x1="5.5" y1="7" x2="8" y2="9" stroke="currentColor" stroke-width="1.2"/><line x1="14.5" y1="7" x2="12" y2="9" stroke="currentColor" stroke-width="1.2"/><line x1="5.5" y1="14" x2="8" y2="11.5" stroke="currentColor" stroke-width="1.2"/><line x1="14.5" y1="14" x2="12" y2="11.5" stroke="currentColor" stroke-width="1.2"/></svg>
            </div>
            <h3 class="feature-title">AI Swarm Engine</h3>
            <p class="feature-desc">Four specialized Qwen agents — Market Analyst, Sentiment Agent, Risk Manager, and Coordinator — collaborate to reach consensus on every trade.</p>
          </div>

          <div class="feature-card">
            <div class="feature-icon feature-icon-violet">
              <svg width="22" height="22" viewBox="0 0 20 20" fill="none"><rect x="2" y="5" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M6 5V4a4 4 0 0 1 8 0v1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="10" cy="11" r="2" fill="currentColor"/></svg>
            </div>
            <h3 class="feature-title">Pacifica Integration</h3>
            <p class="feature-desc">Direct integration with Pacifica perpetuals via REST API and WebSocket. Trades are signed with your Solana wallet — no custody, no trust required.</p>
          </div>

          <div class="feature-card">
            <div class="feature-icon feature-icon-emerald">
              <svg width="22" height="22" viewBox="0 0 20 20" fill="none"><rect x="2" y="11" width="5" height="8" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="7.5" y="6" width="5" height="13" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="13" y="1" width="5" height="18" rx="1" stroke="currentColor" stroke-width="1.5"/></svg>
            </div>
            <h3 class="feature-title">Builder Program Ready</h3>
            <p class="feature-desc">Builder code integration follows Pacifica's documented approval flow with wallet signature and configurable fee rate.</p>
          </div>

          <div class="feature-card">
            <div class="feature-icon feature-icon-rose">
              <svg width="22" height="22" viewBox="0 0 20 20" fill="none"><path d="M10 2L3 6v5c0 4.4 3 8.5 7 9.5 4-1 7-5.1 7-9.5V6L10 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><polyline points="7,10 9,12 13,8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="feature-title">Risk Management</h3>
            <p class="feature-desc">The Risk Manager agent calculates optimal position sizing, leverage, and stop-loss levels based on portfolio balance and market volatility.</p>
          </div>

          <div class="feature-card">
            <div class="feature-icon feature-icon-amber">
              <svg width="22" height="22" viewBox="0 0 20 20" fill="none"><polyline points="2,14 7,9 11,12 18,5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><polyline points="14,5 18,5 18,9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <h3 class="feature-title">Real-time Analytics</h3>
            <p class="feature-desc">Live equity curve, performance metrics (Sharpe ratio, max drawdown, win rate), and per-agent confidence tracking.</p>
          </div>

          <div class="feature-card">
            <div class="feature-icon feature-icon-cyan">
              <svg width="22" height="22" viewBox="0 0 20 20" fill="none"><rect x="2" y="6" width="16" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M6 6V5a4 4 0 0 1 8 0v1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="10" y1="11" x2="10" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="10" cy="10" r="1.5" fill="currentColor"/></svg>
            </div>
            <h3 class="feature-title">Wallet-native Auth</h3>
            <p class="feature-desc">No passwords, no JWT. Connect your Phantom wallet and sign orders with your private key. You stay in full control at all times.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="how-it-works" id="how-it-works">
      <div class="section-inner">
        <div class="section-eyebrow">How it works</div>
        <h2 class="section-title">From market data to executed trade</h2>
        <p class="section-subtitle">Six steps from wallet connection to live performance tracking.</p>
        <div class="steps-grid">

          <div class="step-card">
            <div class="step-number-wrap">
              <div class="step-number">01</div>
              <div class="step-line"></div>
            </div>
            <div class="step-body">
              <h3 class="step-title">Connect Wallet</h3>
              <p class="step-desc">Connect your Phantom or Solflare wallet. No registration, no email required.</p>
            </div>
          </div>

          <div class="step-card">
            <div class="step-number-wrap">
              <div class="step-number">02</div>
              <div class="step-line"></div>
            </div>
            <div class="step-body">
              <h3 class="step-title">Configure Strategy</h3>
              <p class="step-desc">Set your builder code, fee rate, risk parameters, preferred symbols, and leverage limits.</p>
            </div>
          </div>

          <div class="step-card">
            <div class="step-number-wrap">
              <div class="step-number">03</div>
              <div class="step-line"></div>
            </div>
            <div class="step-body">
              <h3 class="step-title">AI Swarm Analyzes</h3>
              <p class="step-desc">Four Qwen agents analyze market data, sentiment, and risk simultaneously.</p>
            </div>
          </div>

          <div class="step-card">
            <div class="step-number-wrap">
              <div class="step-number">04</div>
              <div class="step-line"></div>
            </div>
            <div class="step-body">
              <h3 class="step-title">Consensus Decision</h3>
              <p class="step-desc">The Coordinator aggregates all signals and reaches a final BUY/SELL/HOLD decision.</p>
            </div>
          </div>

          <div class="step-card">
            <div class="step-number-wrap">
              <div class="step-number">05</div>
              <div class="step-line"></div>
            </div>
            <div class="step-body">
              <h3 class="step-title">Signed &amp; Executed</h3>
              <p class="step-desc">Order is signed with your wallet key and submitted to Pacifica API on Solana.</p>
            </div>
          </div>

          <div class="step-card">
            <div class="step-number-wrap">
              <div class="step-number">06</div>
            </div>
            <div class="step-body">
              <h3 class="step-title">Track Performance</h3>
              <p class="step-desc">Monitor live P&amp;L, equity curve, and AI agent confidence in real-time.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta">
      <div class="cta-inner">
        <div class="cta-badge">Get started for free</div>
        <h2 class="cta-title">Ready to trade with AI?</h2>
        <p class="cta-desc">Connect your wallet and let the swarm trade for you on Pacifica. No setup fee, no registration.</p>
        <div class="cta-actions">
          <a href="/dashboard" class="btn-cta-primary">
            Launch App
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/leaderboard" class="btn-cta-outline">View Leaderboard</a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <div class="logo">
            <div class="logo-icon" style="width:28px;height:28px;">
              <svg width="14" height="14" viewBox="0 0 18 18" fill="none">
                <path d="M3 13 L9 5 L15 9" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="15" cy="9" r="2" fill="white"/>
              </svg>
            </div>
            <span class="logo-text">Pacfi AI</span>
          </div>
          <p class="footer-tagline">Autonomous AI Trading on Pacifica Perpetuals</p>
        </div>
        <div class="footer-links">
          <a href="#features">Features</a>
          <a href="#how-it-works">How it works</a>
          <a href="/leaderboard">Leaderboard</a>
          <a href="/dashboard">Launch App</a>
        </div>
        <div class="footer-copy">
          <p>Built for Pacifica Hackathon 2025. Testnet only.</p>
        </div>
      </div>
    </footer>

  </div>
</Layout>

<script>
  // Sticky header shadow
  const header = document.getElementById('header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });

  // Mobile hamburger
  const hamburger = document.getElementById('hamburger');
  const nav = document.getElementById('nav');
  hamburger?.addEventListener('click', () => {
    nav?.classList.toggle('open');
    hamburger?.classList.toggle('active');
  });

  // Close nav on link click
  nav?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      nav?.classList.remove('open');
      hamburger?.classList.remove('active');
    });
  });
</script>

<style>
  /* =============================================
     BASE
  ============================================= */
  * { box-sizing: border-box; margin: 0; padding: 0; }

  .landing {
    min-height: 100vh;
    background: #ffffff;
    color: #1F2937;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  /* =============================================
     HEADER
  ============================================= */
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .header.scrolled {
    border-bottom-color: #E5E7EB;
    box-shadow: 0 1px 12px rgba(0, 0, 0, 0.06);
  }

  .header-inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 24px;
    height: 60px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-icon {
    width: 32px;
    height: 32px;
    background: linear-gradient(135deg, #2563EB, #7C3AED);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .logo-text {
    font-size: 15px;
    font-weight: 800;
    color: #111827;
    letter-spacing: -0.3px;
  }

  .nav {
    display: flex;
    gap: 4px;
    flex: 1;
  }

  .nav a {
    font-size: 13px;
    font-weight: 500;
    color: #6B7280;
    text-decoration: none;
    padding: 6px 12px;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }

  .nav a:hover {
    color: #111827;
    background: #F3F4F6;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .btn-launch {
    padding: 8px 18px;
    background: #111827;
    color: #fff;
    border-radius: 7px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s, transform 0.1s;
    white-space: nowrap;
  }

  .btn-launch:hover {
    background: #1F2937;
    transform: translateY(-1px);
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: none;
    border: 1px solid #E5E7EB;
    border-radius: 7px;
    cursor: pointer;
    padding: 8px;
    transition: background 0.15s;
  }

  .hamburger span {
    display: block;
    height: 1.5px;
    background: #374151;
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .hamburger.active span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .hamburger.active span:nth-child(2) { opacity: 0; }
  .hamburger.active span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* =============================================
     HERO
  ============================================= */
  .hero {
    position: relative;
    background: #F0F4FF;
    padding: 0 0 0;
    overflow: hidden;
    border-bottom: 1px solid #D1D9EE;
  }

  .hero-bg-glow {
    position: absolute;
    top: 0;
    right: 0;
    width: 55%;
    height: 100%;
    background: radial-gradient(ellipse at 80% 30%, rgba(37, 99, 235, 0.08) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero-bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(37,99,235,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(37,99,235,0.05) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }

  /* ---- Ticker ---- */
  .hero-ticker {
    position: relative;
    z-index: 2;
    background: #E8EEF8;
    border-bottom: 1px solid #D1D9EE;
    overflow: hidden;
    height: 34px;
    display: flex;
    align-items: center;
  }

  .ticker-track {
    display: flex;
    align-items: center;
    gap: 20px;
    white-space: nowrap;
    animation: ticker-scroll 32s linear infinite;
    padding-left: 100%;
  }

  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .ticker-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }

  .ticker-sym {
    color: #64748B;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .ticker-val { font-weight: 700; font-variant-numeric: tabular-nums; }
  .ticker-chg { font-weight: 600; font-size: 10px; }
  .ticker-sep { color: #C4CDD8; font-size: 10px; }

  .up   { color: #059669; }
  .down { color: #DC2626; }

  /* ---- Hero inner (2-col) ---- */
  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 1240px;
    margin: 0 auto;
    padding: 64px 32px 72px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
  }

  /* ---- Left ---- */
  .hero-left {}

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 12px;
    background: #ECFDF5;
    border: 1px solid #A7F3D0;
    border-left: 3px solid #10B981;
    font-size: 11px;
    font-weight: 700;
    color: #065F46;
    margin-bottom: 28px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 0;
  }

  .badge-divider {
    display: inline-block;
    width: 1px;
    height: 10px;
    background: #A7F3D0;
  }

  .dot-pulse {
    display: inline-block;
    width: 6px;
    height: 6px;
    background: #10B981;
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(16,185,129,0.4); }
    50% { opacity: 0.6; box-shadow: 0 0 0 4px rgba(16,185,129,0); }
  }

  .hero-title {
    font-size: 52px;
    font-weight: 900;
    color: #0F172A;
    line-height: 1.08;
    letter-spacing: -1.8px;
    margin-bottom: 20px;
  }

  .hero-title-gradient {
    background: linear-gradient(135deg, #2563EB 0%, #7C3AED 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    font-size: 15px;
    color: #475569;
    line-height: 1.75;
    margin-bottom: 32px;
    max-width: 440px;
  }

  .hero-actions {
    display: flex;
    gap: 10px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .btn-hero-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: #2563EB;
    color: #fff;
    border-radius: 0;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.15s;
    letter-spacing: 0.02em;
    border: 1px solid #2563EB;
  }

  .btn-hero-primary:hover { background: #1D4ED8; border-color: #1D4ED8; }

  .btn-hero-outline {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    background: transparent;
    color: #374151;
    border: 1px solid #CBD5E1;
    border-radius: 0;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    letter-spacing: 0.02em;
  }

  .btn-hero-outline:hover {
    background: #EFF6FF;
    color: #1D4ED8;
    border-color: #BFDBFE;
  }

  /* ---- Stats row ---- */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 0;
    border: 1px solid #D1D9EE;
    background: #FFFFFF;
  }

  .hero-stat {
    flex: 1;
    padding: 14px 16px;
    text-align: center;
    border-right: 1px solid #E8EEF8;
  }

  .hero-stat:last-child { border-right: none; }

  .hero-stat-div { display: none; }

  .hero-stat-value {
    display: block;
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.5px;
    line-height: 1.1;
    margin-bottom: 4px;
    font-variant-numeric: tabular-nums;
  }

  .hero-stat-label {
    font-size: 10px;
    color: #94A3B8;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .c-green  { color: #059669; }
  .c-blue   { color: #2563EB; }
  .c-purple { color: #7C3AED; }
  .c-amber  { color: #D97706; }

  /* ---- Right: Terminal ---- */
  .hero-right {
    display: flex;
    align-items: stretch;
  }

  .terminal {
    width: 100%;
    background: #FFFFFF;
    border: 1px solid #D1D9EE;
    border-radius: 0;
    overflow: hidden;
    font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
    font-size: 11px;
    box-shadow: 0 8px 32px rgba(37,99,235,0.08), 0 2px 8px rgba(0,0,0,0.04);
  }

  /* Terminal header bar */
  .term-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #F1F5F9;
    border-bottom: 1px solid #E2E8F0;
    padding: 9px 14px;
  }

  .term-header-left { display: flex; gap: 6px; align-items: center; }
  .term-dot { width: 10px; height: 10px; border-radius: 50%; }
  .term-dot-red    { background: #FCA5A5; }
  .term-dot-yellow { background: #FCD34D; }
  .term-dot-green  { background: #6EE7B7; }

  .term-title {
    font-size: 10px;
    font-weight: 700;
    color: #94A3B8;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .term-live {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 10px;
    font-weight: 700;
    color: #059669;
    letter-spacing: 0.06em;
  }

  /* Price row */
  .term-price-row {
    padding: 14px 16px 10px;
    border-bottom: 1px solid #F1F5F9;
  }

  .term-price-main {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 6px;
  }

  .term-price {
    font-size: 26px;
    font-weight: 800;
    color: #0F172A;
    letter-spacing: -0.5px;
    font-variant-numeric: tabular-nums;
    font-family: 'Inter', sans-serif;
  }

  .term-price-chg {
    font-size: 12px;
    font-weight: 700;
  }

  .term-price-meta {
    display: flex;
    gap: 16px;
    font-size: 10px;
    color: #94A3B8;
    font-family: 'Inter', sans-serif;
  }

  .term-price-meta strong { color: #64748B; }

  /* Chart */
  .term-chart {
    padding: 10px 16px 6px;
    border-bottom: 1px solid #F1F5F9;
    background: #FAFBFF;
  }

  .term-chart-labels {
    display: flex;
    flex-direction: column;
    gap: 0;
    float: left;
    font-size: 9px;
    color: #CBD5E1;
    font-family: 'Inter', sans-serif;
    line-height: 1;
    margin-right: 6px;
    justify-content: space-between;
    height: 72px;
    padding: 2px 0;
  }

  .term-spark {
    display: block;
    width: calc(100% - 50px);
    height: 72px;
    margin-left: 44px;
  }

  .term-chart-times {
    display: flex;
    justify-content: space-between;
    font-size: 9px;
    color: #CBD5E1;
    font-family: 'Inter', sans-serif;
    padding: 4px 0 0 44px;
    clear: both;
  }

  /* Agents */
  .term-section-label {
    padding: 8px 16px 6px;
    font-size: 9px;
    font-weight: 700;
    color: #CBD5E1;
    letter-spacing: 0.1em;
    border-top: 1px solid #F1F5F9;
  }

  .term-agents {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: #E8EEF8;
    border-top: 1px solid #F1F5F9;
  }

  .term-agent {
    background: #FFFFFF;
    padding: 10px 12px;
  }

  .term-agent-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 7px;
  }

  .term-agent-name {
    font-size: 10px;
    color: #374151;
    font-weight: 600;
    font-family: 'Inter', sans-serif;
  }

  .term-agent-decision {
    font-size: 9px;
    font-weight: 800;
    padding: 2px 6px;
    letter-spacing: 0.05em;
    border-radius: 0;
  }

  .term-agent-decision.buy  { background: #ECFDF5; color: #059669; border: 1px solid #A7F3D0; }
  .term-agent-decision.hold { background: #FFFBEB; color: #D97706; border: 1px solid #FDE68A; }
  .term-agent-decision.sell { background: #FEF2F2; color: #DC2626; border: 1px solid #FECACA; }

  .term-conf-bar {
    height: 3px;
    background: #E8EEF8;
    margin-bottom: 5px;
  }

  .term-conf-fill {
    height: 100%;
    transition: width 0.3s ease;
  }

  .term-conf-label {
    font-size: 9px;
    color: #94A3B8;
    font-family: 'Inter', sans-serif;
  }

  .term-conf-label strong { color: #64748B; }

  /* Orders */
  .term-orders {
    padding: 0 0 12px;
  }

  .term-order-row {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 7px 12px;
    border-bottom: 1px solid #F8FAFC;
    font-family: 'Inter', sans-serif;
  }

  .term-order-row:last-child { border-bottom: none; }

  .term-order-side {
    font-size: 9px;
    font-weight: 800;
    width: 46px;
    padding: 2px 0;
    text-align: center;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    border-radius: 0;
  }

  .term-order-side.buy  { color: #059669; border: 1px solid #A7F3D0; background: #ECFDF5; }
  .term-order-side.sell { color: #DC2626; border: 1px solid #FECACA; background: #FEF2F2; }

  .term-order-sym  { flex: 1; font-size: 10px; font-weight: 600; color: #374151; padding-left: 10px; }
  .term-order-size { width: 72px; font-size: 10px; color: #94A3B8; font-variant-numeric: tabular-nums; }
  .term-order-pnl  { width: 72px; font-size: 10px; font-weight: 700; text-align: right; font-variant-numeric: tabular-nums; }
  .term-order-time { width: 52px; font-size: 9px; color: #CBD5E1; text-align: right; }

  /* =============================================
     SECTION SHARED
  ============================================= */
  .section-inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 80px 24px;
  }

  .section-eyebrow {
    font-size: 11px;
    font-weight: 700;
    color: #2563EB;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 10px;
  }

  .section-title {
    font-size: 32px;
    font-weight: 800;
    color: #111827;
    letter-spacing: -0.5px;
    margin-bottom: 12px;
    line-height: 1.2;
  }

  .section-subtitle {
    font-size: 15px;
    color: #6B7280;
    margin-bottom: 44px;
    line-height: 1.6;
    max-width: 520px;
  }

  /* =============================================
     FEATURES
  ============================================= */
  .features {
    background: #F8FAFC;
    border-top: 1px solid #E5E7EB;
    border-bottom: 1px solid #E5E7EB;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .feature-card {
    background: #ffffff;
    border: 1px solid #E5E7EB;
    border-radius: 12px;
    padding: 24px;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .feature-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.07);
    transform: translateY(-2px);
  }

  .feature-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    flex-shrink: 0;
  }

  .feature-icon-blue   { background: #EFF6FF; color: #2563EB; }
  .feature-icon-violet { background: #F5F3FF; color: #7C3AED; }
  .feature-icon-emerald{ background: #ECFDF5; color: #059669; }
  .feature-icon-rose   { background: #FFF1F2; color: #E11D48; }
  .feature-icon-amber  { background: #FFFBEB; color: #D97706; }
  .feature-icon-cyan   { background: #ECFEFF; color: #0891B2; }

  .feature-title {
    font-size: 14px;
    font-weight: 700;
    color: #111827;
    margin-bottom: 8px;
    letter-spacing: -0.1px;
  }

  .feature-desc {
    font-size: 13px;
    color: #6B7280;
    line-height: 1.65;
  }

  /* =============================================
     HOW IT WORKS
  ============================================= */
  .how-it-works {
    background: #ffffff;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0 32px;
  }

  .step-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-bottom: 40px;
  }

  .step-number-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }

  .step-number {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, #EFF6FF, #E0E7FF);
    border: 1.5px solid #BFDBFE;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 800;
    color: #2563EB;
    flex-shrink: 0;
    letter-spacing: -0.2px;
  }

  .step-line {
    flex: 1;
    height: 1.5px;
    background: linear-gradient(90deg, #BFDBFE, transparent);
  }

  .step-body {}

  .step-title {
    font-size: 14px;
    font-weight: 700;
    color: #111827;
    margin-bottom: 7px;
    letter-spacing: -0.1px;
  }

  .step-desc {
    font-size: 13px;
    color: #6B7280;
    line-height: 1.65;
  }

  /* =============================================
     CTA
  ============================================= */
  .cta {
    background: linear-gradient(135deg, #1E3A8A 0%, #312E81 100%);
    padding: 88px 24px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }

  .cta-inner {
    position: relative;
    max-width: 520px;
    margin: 0 auto;
  }

  .cta-badge {
    display: inline-block;
    padding: 4px 12px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 20px;
    font-size: 11px;
    font-weight: 700;
    color: #BFDBFE;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 20px;
  }

  .cta-title {
    font-size: 34px;
    font-weight: 900;
    color: #ffffff;
    letter-spacing: -0.8px;
    margin-bottom: 14px;
    line-height: 1.2;
  }

  .cta-desc {
    font-size: 15px;
    color: #93C5FD;
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .cta-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 28px;
    background: #ffffff;
    color: #1E3A8A;
    border-radius: 9px;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.15s, transform 0.1s;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  }

  .btn-cta-primary:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }

  .btn-cta-outline {
    display: inline-flex;
    align-items: center;
    padding: 13px 28px;
    background: transparent;
    color: #BFDBFE;
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 9px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .btn-cta-outline:hover {
    background: rgba(255,255,255,0.08);
    color: #fff;
  }

  /* =============================================
     FOOTER
  ============================================= */
  .footer {
    background: #F9FAFB;
    border-top: 1px solid #E5E7EB;
    padding: 32px 24px;
  }

  .footer-inner {
    max-width: 1140px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .footer-tagline {
    font-size: 12px;
    color: #9CA3AF;
    margin: 0;
  }

  .footer-links {
    display: flex;
    gap: 4px;
  }

  .footer-links a {
    font-size: 13px;
    color: #6B7280;
    text-decoration: none;
    padding: 5px 10px;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }

  .footer-links a:hover {
    color: #111827;
    background: #F3F4F6;
  }

  .footer-copy {
    font-size: 12px;
    color: #9CA3AF;
  }

  .footer-copy p { color: #9CA3AF; }

  /* =============================================
     RESPONSIVE — TABLET (≤ 1024px)
  ============================================= */
  @media (max-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 56px 24px 48px;
    }

    .hero-title {
      font-size: 42px;
    }

    .hero-right {
      max-width: 100%;
    }

    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .steps-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0 24px;
    }

    .section-title {
      font-size: 26px;
    }
  }

  /* =============================================
     RESPONSIVE — MOBILE (≤ 640px)
  ============================================= */
  @media (max-width: 640px) {
    /* Header */
    .nav {
      display: none;
      position: absolute;
      top: 60px;
      left: 0;
      right: 0;
      background: #ffffff;
      border-bottom: 1px solid #E5E7EB;
      flex-direction: column;
      gap: 2px;
      padding: 8px 16px 12px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    }

    .nav.open { display: flex; }
    .nav a { padding: 10px 12px; font-size: 14px; }
    .header { position: sticky; }
    .hamburger { display: flex; }
    .btn-launch { display: none; }

    /* Hero */
    .hero-inner {
      padding: 40px 16px 40px;
      gap: 32px;
    }

    .hero-title {
      font-size: 32px;
      letter-spacing: -1px;
