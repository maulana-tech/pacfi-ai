---
import Layout from '../layouts/Layout.astro';
import SwarmMonitor from '../components/SwarmMonitor';
import PortfolioStats from '../components/PortfolioStats';
---

<Layout title="Pacfi AI - Dashboard">
  <main class="container">
    <header class="p-6 flex justify-between items-center border-b">
      <div>
        <h1>Dashboard</h1>
        <p class="text-gray-600 text-sm mt-1">Monitor your trading swarm in real-time</p>
      </div>
      <div class="flex gap-4">
        <button class="bg-white border rounded px-4 py-2">Settings</button>
        <button class="bg-white border rounded px-4 py-2">Logout</button>
      </div>
    </header>

    <div class="p-6 grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-1">
        <PortfolioStats client:load />
      </div>

      <div class="lg:col-span-2">
        <SwarmMonitor client:load />
      </div>
    </div>
  </main>
</Layout>

<style>
  button {
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  button:hover {
    background-color: #f9fafb;
  }
</style>
