---
import '../styles/global.css';
import Sidebar from '../components/Sidebar';

interface Props {
  title: string;
  activeNav?: string;
}

const { title, activeNav = 'dashboard' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Pacfi AI</title>
  </head>
  <body>
    <div class="app-shell">
      <Sidebar client:load activeNav={activeNav} />
      <div class="app-main">
        <slot />
      </div>
    </div>
  </body>
</html>

<style>
  .app-shell {
    display: flex;
    height: 100vh;
    overflow: hidden;
    background: #F9FAFB;
  }

  .app-main {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    display: flex;
    flex-direction: column;
  }
</style>
