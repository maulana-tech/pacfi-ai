{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "lib": ["ES2020"],
    "target": "ES2020",
    "rootDir": "./src",
    "noEmit": false,
    "declaration": false,
    "module": "ES2020",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": false,
    "allowImportingTsExtensions": false
  },
  "include": ["src"]
}
